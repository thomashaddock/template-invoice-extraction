# ============================================================
# Streamlit app (frontend) — Heroku / local run
# Copy to .env in project root for local run, or set Heroku config vars. Never commit .env.
# ============================================================

# Required: CrewAI Enterprise API (from AMP after deploying the flow)
CREWAI_ENTERPRISE_API_URL=https://your-instance.crewai.com
CREWAI_ENTERPRISE_BEARER_TOKEN=your-bearer-token

# Required: Google Drive (app uploads PDFs here, then triggers the flow)
# Set to file path or JSON string: {"type":"service_account",...}
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_FOLDER_ID=

# Optional: Webhook (currently unused; app uses polling)
# CREWAI_WEBHOOK_URL=https://your-app.herokuapp.com/webhook
# WEBHOOK_BEARER_TOKEN=generate-a-random-secret
# WEBHOOK_SERVER_PORT=8000
