# ============================================================
# CrewAI Flow (runs on CrewAI Enterprise)
# These are configured in the CrewAI Enterprise environment,
# NOT needed by the Streamlit app.
# ============================================================

OPENAI_API_KEY=sk-...

# Heroku Postgres (used by DBWriterTool inside the flow)
DATABASE_URL=postgres://user:pass@host:5432/dbname

# CrewAI platform integration token (AMP → Settings → Integrations)
CREWAI_PLATFORM_INTEGRATION_TOKEN=PK_...

# Enable tracing for debugging
CREWAI_TRACING_ENABLED=true

# Google Drive (used by the flow to download PDFs)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"...@...iam.gserviceaccount.com",...}
GOOGLE_DRIVE_FOLDER_ID=1aBcDeFgHiJkLmNoPqRsTuVwXyZ

# ============================================================
# Streamlit App (runs on Heroku)
# These are set as Heroku config vars.
# ============================================================

# CrewAI Enterprise API
CREWAI_ENTERPRISE_API_URL=https://...crewai.com
CREWAI_ENTERPRISE_BEARER_TOKEN=...

# Webhook — CrewAI Enterprise posts results here on completion.
# CREWAI_WEBHOOK_URL is the public URL CrewAI will POST to.
# WEBHOOK_BEARER_TOKEN is a shared secret: we send it in the kickoff
# webhooks config, and CrewAI echoes it back in the Authorization header
# so we can verify the callback is legitimate.
CREWAI_WEBHOOK_URL=https://your-heroku-app.herokuapp.com/webhook
WEBHOOK_BEARER_TOKEN=some-random-secret-you-generate
WEBHOOK_SERVER_PORT=8000

# Google Drive (used by the Streamlit app to upload/list PDFs)
# GOOGLE_SERVICE_ACCOUNT_JSON=  (same as above, shared between crew and app)
# GOOGLE_DRIVE_FOLDER_ID=       (same as above)
