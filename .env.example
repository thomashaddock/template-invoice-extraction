# ============================================================
# doc2data — Invoice Extraction (CrewAI)
# Copy this file to .env and fill in real values.
# NEVER commit .env or any file containing real API keys.
# ============================================================

# ----- CrewAI Flow (CrewAI Enterprise / local flow run) -----
# Required for LLM calls in the flow.
OPENAI_API_KEY=sk-your-openai-key-here
GROQ_API_KEY=gsk-your-groq-key-here

# Optional: CrewAI platform integration (AMP → Settings → Integrations)
# CREWAI_PLATFORM_INTEGRATION_TOKEN=PK_...

# Optional: Enable tracing for debugging
# CREWAI_TRACING_ENABLED=true

# Google Drive — required when running the flow (downloads PDFs) or Streamlit app (upload/list).
# Either path to a JSON key file or the JSON object as a string.
# GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account-key.json
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"...@....iam.gserviceaccount.com",...}
# GOOGLE_DRIVE_FOLDER_ID=your-drive-folder-id

# Optional: Heroku Postgres (only if enabling DBWriterTool in the flow)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require

# ----- Streamlit App (e.g. Heroku) -----
# Required for the demo app to trigger flows and poll status.
CREWAI_ENTERPRISE_API_URL=https://your-instance.crewai.com
CREWAI_ENTERPRISE_BEARER_TOKEN=your-bearer-token

# Optional: Webhook (currently unused; app uses polling)
# CREWAI_WEBHOOK_URL=https://your-app.herokuapp.com/webhook
# WEBHOOK_BEARER_TOKEN=generate-a-random-secret
# WEBHOOK_SERVER_PORT=8000
