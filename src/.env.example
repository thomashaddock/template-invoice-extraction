# ============================================================
# CrewAI flow (invoice_extraction) — deploy to CrewAI Enterprise / run locally
# Copy to .env in this directory (or set in AMP dashboard). Never commit .env.
# ============================================================

# Required for LLM calls in the flow
OPENAI_API_KEY=sk-your-openai-key-here
GROQ_API_KEY=gsk-your-groq-key-here

# Google Drive — flow downloads PDFs from here (e.g. after Streamlit upload)
# Set to file path or JSON string: {"type":"service_account",...}
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_FOLDER_ID=

# Optional: CrewAI platform (AMP → Settings → Integrations)
# CREWAI_PLATFORM_INTEGRATION_TOKEN=PK_...

# Optional: Tracing
# CREWAI_TRACING_ENABLED=true

# Optional: Postgres (only if you enable DBWriterTool in the flow)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require
